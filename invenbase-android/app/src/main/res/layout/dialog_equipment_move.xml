<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/move_to_squad"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />
    <Spinner
        android:id="@+id/spinner_move_squad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/move_to_location"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/edit_move_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:hint="@string/location"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/move_comment"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/edit_move_comment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textMultiLine|textCapSentences"
        android:minLines="3"
        android:gravity="top"
        android:hint="@string/move_comment_hint"
        android:layout_marginBottom="16dp" />
</LinearLayout>
