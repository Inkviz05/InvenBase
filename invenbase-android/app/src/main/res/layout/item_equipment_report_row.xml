<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="48dp">

    <TextView
        android:id="@+id/text_row_num"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_row_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/text_row_category"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:layout_marginStart="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/text_row_total"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/text_row_available"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/success"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/text_row_booked"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/warning"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/text_row_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:layout_marginStart="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
