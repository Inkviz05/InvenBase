<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/squad_name"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/edit_squad_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textCapSentences"
        android:hint="@string/squad_name"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/squad_location"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/edit_squad_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:hint="@string/squad_location"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/squad_responsible"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />
    <Spinner
        android:id="@+id/spinner_squad_responsible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:minHeight="48dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/squad_description"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/edit_squad_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textMultiLine|textCapSentences"
        android:minLines="3"
        android:gravity="top"
        android:hint="@string/squad_description"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_squad_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textSize="16sp"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_marginEnd="8dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_squad_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/save"
            android:textSize="16sp"
            style="@style/Widget.Material3.Button" />
    </LinearLayout>
</LinearLayout>
