<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Камера сканера (видна только при сканировании) -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_scanner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Статус сканирования (только при активном сканировании, компактный) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_scan_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical"
            android:minWidth="120dp">

            <ProgressBar
                android:id="@+id/progress_scanning"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="12dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_scan_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scanning_in_progress"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_normal"
                android:textStyle="normal"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Кнопка остановки (только при активном сканировании, внизу экрана, компактная) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_stop_scanning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/stop_scanning"
        android:textSize="@dimen/text_size_normal"
        android:minHeight="48dp"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Интерфейс до начала сканирования -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/start_scan_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷"
                android:textSize="80sp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/text_scanner_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/scan_qr_code"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_xlarge"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/scan_qr_hint"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_medium"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="40dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_start_scanning"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/start_scanning"
                android:textSize="@dimen/text_size_medium"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.Button" />

            <!-- Ручной ввод вынесен в быстрые действия на дашборде -->
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
