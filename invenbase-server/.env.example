DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kvantoriym
HOST=127.0.0.1
PORT=8080

# Use a unique secret with at least 32 random characters.
JWT_SECRET=change-me-use-a-long-random-secret-minimum-32-chars
JWT_EXPIRATION=86400

# Optional first admin seed. Enable only for initial setup, then turn off.
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_EMAIL=admin@kvantoriym.local
DEFAULT_ADMIN_FULL_NAME=Administrator

# Comma-separated list. Example: http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Firebase Cloud Messaging HTTP v1 API.
# Keep the service account JSON outside git.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_PATH=

# Legacy FCM server key is deprecated. Leave empty unless you intentionally support it.
FCM_SERVER_KEY=
